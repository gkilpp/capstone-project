      <column caption='Conversion Rate' datatype='real' default-format='p0.00%' name='[Calculation_2015743524347904]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(converted) / COUNT([converted])' />
      </column>
      <column caption='Engagement' datatype='real' name='[Calculation_2015743524839425]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG(pageviews)' />
      </column>
      <column caption='Engagement Efficiency' datatype='real' default-format='p0.00%' name='[Calculation_2015743525683202]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(converted) / SUM(pageviews)' />
      </column>
      <column caption='Conversion Rate 2' datatype='real' name='[Calculation_2015743552495628]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([converted]) / COUNTD([session_id])' />
      </column>
      <column caption='bucket' datatype='string' name='[Calculation_2015743557181453]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [pageviews] &lt;= 5 THEN &quot;0–5&quot;&#13;&#10;ELSEIF [pageviews] &lt;= 10 THEN &quot;5–10&quot;&#13;&#10;ELSEIF [pageviews] &lt;= 15 THEN &quot;10–15&quot;&#13;&#10;ELSEIF [pageviews] &lt;= 20 THEN &quot;15–20&quot;&#13;&#10;ELSEIF [pageviews] &lt;= 25 THEN &quot;20–25&quot;&#13;&#10;ELSEIF [pageviews] &lt;= 30 THEN &quot;25–30&quot;&#13;&#10;ELSEIF [pageviews] &lt;= 35 THEN &quot;30–35&quot;&#13;&#10;ELSEIF [pageviews] &lt;= 40 THEN &quot;35–40&quot;&#13;&#10;ELSEIF [pageviews] &lt;= 45 THEN &quot;40–45&quot;&#13;&#10;ELSEIF [pageviews] &lt;= 50 THEN &quot;45–50&quot;&#13;&#10;ELSE &quot;50+&quot;&#13;&#10;END' />
